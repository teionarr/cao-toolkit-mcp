{
  "name": "cao-toolkit-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "Remote MCP server that runs the Chief Agency Officer toolkit-without-the-title playbook — COO mandate, first four moves, monthly cadence, month-6 reassessment.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
